{
  "name": "@mgvdev/nestkit-compiler-tsc",
  "version": "0.2.2",
  "description": "TypeScript adapter for nestkit: typecheck (--noEmit) and .d.ts generation for libraries.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mgvdev/nestkit-core": "^0.2.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0 <7"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgvdev/nestkit.git",
    "directory": "packages/compiler-tsc"
  },
  "homepage": "https://github.com/mgvdev/nestkit#readme",
  "bugs": {
    "url": "https://github.com/mgvdev/nestkit/issues"
  }
}
